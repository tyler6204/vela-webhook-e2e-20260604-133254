+def _json_depth(value, depth=0):
+    if isinstance(value, dict):
+        return max([depth] + [_json_depth(item, depth + 1) for item in value.values()])
+    if isinstance(value, list):
+        return max([depth] + [_json_depth(item, depth + 1) for item in value])
+    return depth
+
+
+def _common_fields(payload: dict) -> dict:
+    repository = _expect_dict(payload, "repository")
+    repository_name = _expect_string(repository, "full_name")
+    if "/" not in repository_name:
+        raise MalformedPayload("repository.full_name must be owner/name")
+
+    sender = _expect_dict(payload, "sender")
+    sender_login = _expect_string(sender, "login")
+
+    installation_id = None
+    installation = payload.get("installation")
+    if installation is not None:
+        if not isinstance(installation, dict):
+            raise MalformedPayload("installation must be an object")
+        installation_id = _expect_positive_int(installation, "id")
+
+    return {
+        "repository": repository_name,
+        "sender": sender_login,
+        "installation_id": installation_id,
+    }
+
+
+def _normalize_push(payload: dict, delivery_id: str, common: dict) -> NormalizedEvent:
+    ref = _expect_ref(payload, "ref")
+    before = _expect_sha(payload, "before")
+    after = _expect_sha(payload, "after")
+    created = _expect_bool(payload, "created")
+    deleted = _expect_bool(payload, "deleted")
+    forced = _expect_bool(payload, "forced")
+
+    if created and deleted:
+        raise MalformedPayload("push cannot be both created and deleted")
+    if deleted and after != _ZERO_SHA:
+        raise MalformedPayload("deleted pushes must use the zero after SHA")
+    if created and before != _ZERO_SHA:
+        raise MalformedPayload("created pushes must use the zero before SHA")
+
+    if deleted:
+        action = "deleted"
+        sha = None
+    elif created:
+        action = "created"
+        sha = after
+    elif forced:
+        action = "forced"
+        sha = after
+    else:
+        action = "updated"
+        sha = after
+
+    commits_value = payload.get("commits", [])
+    if not isinstance(commits_value, list):
+        raise MalformedPayload("commits must be an array")
+
+    commit_ids = []
+    messages = []
+    changed_files = set()
+    for index, commit in enumerate(commits_value):
+        if not isinstance(commit, dict):
+            raise MalformedPayload(f"commits[{index}] must be an object")
+        commit_ids.append(_expect_sha(commit, "id", f"commits[{index}].id"))
+        messages.append(_expect_string(commit, "message", f"commits[{index}].message"))
+        changed_files.update(_commit_files(commit, f"commits[{index}]"))
+
+    head_commit = payload.get("head_commit")
+    if head_commit is not None:
+        if not isinstance(head_commit, dict):
+            raise MalformedPayload("head_commit must be an object or null")
+        head_message = _expect_string(head_commit, "message", "head_commit.message")
+        if head_message not in messages:
+            messages.insert(0, head_message)
+        changed_files.update(_commit_files(head_commit, "head_commit"))
+
+    return NormalizedEvent(
+        event="push",
+        delivery_id=delivery_id,
+        repository=common["repository"],
+        action=action,
+        ref=ref,
+        sha=sha,
+        sender=common["sender"],
+        installation_id=common["installation_id"],
+        before=before,
+        commits=tuple(commit_ids),
+        changed_files=tuple(sorted(changed_files)),
+        messages=tuple(messages),
+        forced=forced,
+        deleted=deleted,
+        skip_ci=_contains_default_skip_token(messages),
+    )
+
+
+def _normalize_pull_request(
+    payload: dict,
+    delivery_id: str,
+    common: dict,
+) -> NormalizedEvent:
+    action = _expect_string(payload, "action")
+    if action not in _PULL_REQUEST_ACTIONS:
+        raise UnsupportedEvent(f"unsupported pull_request action: {action}")
+    number = _expect_positive_int(payload, "number")
+    pull_request = _expect_dict(payload, "pull_request")
+    draft = _expect_bool(pull_request, "draft", "pull_request.draft")
+    merged = _expect_bool(pull_request, "merged", "pull_request.merged")
+    head = _expect_dict(pull_request, "head", "pull_request.head")
+    base = _expect_dict(pull_request, "base", "pull_request.base")
+    head_sha = _expect_sha(head, "sha", "pull_request.head.sha")
+    base_sha = _expect_sha(base, "sha", "pull_request.base.sha")
+    head_ref = _expect_branch(head, "ref", "pull_request.head.ref")
+    base_branch = _expect_branch(base, "ref", "pull_request.base.ref")
+    head_repo = _expect_dict(head, "repo", "pull_request.head.repo")
+    head_repo_name = _expect_string(
+        head_repo,
+        "full_name",
+        "pull_request.head.repo.full_name",
+    )
+
+    sha = head_sha
+    if action == "closed" and merged:
+        merge_sha = pull_request.get("merge_commit_sha")
+        if merge_sha is not None:
+            sha = _validate_sha(merge_sha, "pull_request.merge_commit_sha")
+
+    return NormalizedEvent(
+        event="pull_request",
+        delivery_id=delivery_id,
+        repository=common["repository"],
+        action=action,
+        ref=f"refs/pull/{number}/head",
+        sha=sha,
+        sender=common["sender"],
+        installation_id=common["installation_id"],
+        base_ref=f"refs/heads/{base_branch}",
+        base_sha=base_sha,
+        number=number,
+        fork=head_repo_name.casefold() != common["repository"].casefold(),
+        draft=draft,
+    )
+
+
+def _normalize_merge_group(
+    payload: dict,
+    delivery_id: str,
+    common: dict,
+) -> NormalizedEvent:
+    action = _expect_string(payload, "action")
+    if action not in _MERGE_GROUP_ACTIONS:
+        raise UnsupportedEvent(f"unsupported merge_group action: {action}")
+    group = _expect_dict(payload, "merge_group")
+    head_sha = _expect_sha(group, "head_sha", "merge_group.head_sha")
+    head_ref = _expect_ref(group, "head_ref", "merge_group.head_ref")
+    base_sha = _expect_sha(group, "base_sha", "merge_group.base_sha")
+    base_ref = _expect_ref(group, "base_ref", "merge_group.base_ref")
+
+    return NormalizedEvent(
+        event="merge_group",
+        delivery_id=delivery_id,
+        repository=common["repository"],
+        action=action,
+        ref=head_ref,
+        sha=head_sha,
+        sender=common["sender"],
+        installation_id=common["installation_id"],
+        base_ref=base_ref,
+        base_sha=base_sha,
+    )
+
+
+def _commit_files(commit: dict, path: str) -> Iterable[str]:
+    files = []
+    for key in ("added", "modified", "removed"):
+        value = commit.get(key, [])
+        if not isinstance(value, list):
+            raise MalformedPayload(f"{path}.{key} must be an array")
+        for index, filename in enumerate(value):
+            if not isinstance(filename, str) or not filename:
+                raise MalformedPayload(f"{path}.{key}[{index}] must be a non-empty string")
+            files.append(filename)
+    return files
+
+
+def _expect_dict(container: dict, key: str, path: Optional[str] = None) -> dict:
+    value = container.get(key)
+    if not isinstance(value, dict):
+        raise MalformedPayload(f"{path or key} must be an object")
+    return value
+
+
+def _expect_string(container: dict, key: str, path: Optional[str] = None) -> str:
+    value = container.get(key)
+    if not isinstance(value, str) or not value:
+        raise MalformedPayload(f"{path or key} must be a non-empty string")
+    return value
+
+
+def _expect_bool(container: dict, key: str, path: Optional[str] = None) -> bool:
+    value = container.get(key)
+    if not isinstance(value, bool):
+        raise MalformedPayload(f"{path or key} must be a boolean")
+    return value
+
+
+def _expect_positive_int(container: dict, key: str, path: Optional[str] = None) -> int:
+    value = container.get(key)
+    if isinstance(value, bool) or not isinstance(value, int) or value <= 0:
+        raise MalformedPayload(f"{path or key} must be a positive integer")
+    return value
+
+
+def _expect_sha(container: dict, key: str, path: Optional[str] = None) -> str:
+    return _validate_sha(container.get(key), path or key)
+
+
+def _validate_sha(value, path: str) -> str:
+    if not isinstance(value, str) or _SHA_RE.fullmatch(value) is None:
+        raise MalformedPayload(f"{path} must be a 40-character lowercase hex SHA")
+    return value
+
+
+def _expect_ref(container: dict, key: str, path: Optional[str] = None) -> str:
+    value = _expect_string(container, key, path)
+    if not value.startswith("refs/") or any(character.isspace() for character in value):
+        raise MalformedPayload(f"{path or key} must be a canonical refs/ value")
+    return value
+
+
+def _expect_branch(container: dict, key: str, path: str) -> str:
+    value = _expect_string(container, key, path)
+    if value.startswith("refs/") or value.startswith("/") or value.endswith("/"):
+        raise MalformedPayload(f"{path} must be a branch name")
+    if any(character.isspace() for character in value):
+        raise MalformedPayload(f"{path} must not contain whitespace")
+    return value
+
+
+def _matches_any(value: str, patterns: Sequence[str]) -> bool:
+    return any(fnmatchcase(value, pattern) for pattern in patterns)
+
+
+def _contains_default_skip_token(messages: Sequence[str]) -> bool:
+    combined = "\n".join(messages).casefold()
+    return "[skip ci]" in combined or "[ci skip]" in combined
